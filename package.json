{
  "name": "relationship-memory-time-machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "project:website": "npm run pipeline:run && npm run build",
    "project:ebook": "npm run ebook:build && npm run ebook:pdf",
    "project:all": "npm run pipeline:run && npm run build && npm run ebook:build && npm run ebook:pdf",
    "ebook:build": "tsx scripts/generate-ebook.ts",
    "ebook:pdf": "powershell -ExecutionPolicy Bypass -File scripts/render-ebook-pdf.ps1",
    "pipeline:parse": "tsx pipeline/exec/parse-whatsapp.ts",
    "pipeline:analyze": "tsx pipeline/orchestration/analyze.ts",
    "pipeline:consolidate": "tsx pipeline/orchestration/consolidate.ts",
    "pipeline:curate": "tsx pipeline/orchestration/curate.ts",
    "pipeline:publish": "tsx pipeline/exec/publish.ts",
    "pipeline:run": "tsx pipeline/orchestration/run.ts"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.577.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
